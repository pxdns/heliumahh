{
  "name": "heliumahh",
  "version": "1.0.0",
  "description": "Minecraft texture pack tools — cleaner, converter, and pack browser",
  "main": "main.js",
  "author": "pxdns",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "24.13.3"
  },
  "build": {
    "appId": "com.pxdns.heliumahh",
    "productName": "helium",
    "icon": "build/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!.git/**",
      "!.kiro/**",
      "!.github/**",
      "!node_modules/.cache/**",
      "!dist/**"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
